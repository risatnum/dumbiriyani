# Discord Bot Environment Variables Configuration Template
# Copy this file to a new file named '.env' in the same folder and fill in the values.

# The token for your Discord bot (obtained from the Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Gemini API Key (obtained from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# The base URL of the running FastAPI backend
BACKEND_URL=http://localhost:8000
