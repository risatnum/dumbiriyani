# Backend Environment Variables Configuration Template
# Copy this file to a new file named '.env' in the same folder and customize values if needed.

# Electricity tariff rate per kWh (for bill calculation)
ELECTRICITY_RATE_PER_KWH=8

# Office operational hours (for after-hours alerts)
OFFICE_OPEN_HOUR=9
OFFICE_CLOSE_HOUR=17

# CORS allowed origins (separated by commas)
CORS_ORIGINS=http://localhost:5173
